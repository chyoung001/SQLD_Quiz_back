# MongoDB Atlas 연결 문자열
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/sqld_quiz?retryWrites=true&w=majority

# Anthropic (Claude) API 키
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Gemini API 키
GEMINI_API_KEY=AIzaSy...

# CORS 허용 오리진 — 쉼표로 구분, 공백 없이 작성
# 로컬 개발만: (기본값이라 생략 가능)
# CORS_ORIGINS=http://localhost:5173
# 배포 환경 (Railway 환경변수에 설정):
CORS_ORIGINS=https://sqld-quiz-front.vercel.app,http://localhost:5173

# 관리자 엔드포인트(/api/admin/*) 보호 토큰
# 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 미설정 시 admin API는 503으로 비활성화됨
ADMIN_TOKEN=

# LLM 생성 엔드포인트(/api/llm/generate) IP당 분당 최대 호출 수 (기본 3)
LLM_RATE_LIMIT_PER_MINUTE=3
